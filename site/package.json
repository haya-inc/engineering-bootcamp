{
  "name": "engineering-bootcamp-site",
  "version": "0.0.1",
  "private": true,
  "description": "エンジニア入門研修の公開教材サイト (Astro)。",
  "type": "module",
  "scripts": {
    "split": "node scripts/split-book.mjs",
    "dev": "node scripts/split-book.mjs && astro dev",
    "build": "node scripts/split-book.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "node scripts/split-book.mjs && vp check",
    "typecheck": "node scripts/split-book.mjs && astro check",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "test": "vp test run"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.2",
    "astro-icon": "1.1.5",
    "sharp": "0.35.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@iconify-json/ph": "1.2.2",
    "pagefind": "1.5.2",
    "typescript": "6.0.3",
    "vite-plus": "0.2.1"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "bun@1.3.14",
  "comment": "本番デプロイに乗る依存は exact 固定 (caret 不使用)。更新は意図的に行う。alpha の vite-plus も固定。",
  "trustedDependencies": [
    "esbuild",
    "sharp"
  ]
}
