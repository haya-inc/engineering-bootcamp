---
// Pagefind による静的サイト内検索。ビルド時に dist を索引化し、外部サービス無しで動く。
// 索引はビルド後にしか存在しないため、dev では結果が出ない (本番ビルドで有効)。
import { Icon } from "astro-icon/components";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const bundlePath = `${base}/pagefind/`;
---

<dialog
  class="search-dialog"
  data-search-dialog
  aria-labelledby="search-dialog-title"
>
  <div class="search-dialog__inner">
    <div class="search-dialog__bar">
      <p class="search-dialog__title" id="search-dialog-title">教材を検索</p>
      <button
        type="button"
        class="search-dialog__close"
        data-search-close
        aria-label="検索を閉じる"
      >
        <Icon name="ph:x" aria-hidden="true" />
      </button>
    </div>
    <div id="pagefind-search" data-bundle-path={bundlePath}></div>
  </div>
</dialog>

<script>
  // 初回オープン時に Pagefind UI を遅延ロードする。
  // 注意: <dialog> / mount / 閉じるボタンは BaseLayout の <body> 内にあり、View Transitions
  // (ClientRouter) のページ遷移ごとに差し替わる。モジュール評価時に1度だけ掴むと遷移後に
  // detached な旧ノードを指し続け、showModal() が InvalidStateError で無言故障する。
  // そのため要素は毎回ライブで引き直す (getDialog / getMount / 引数渡し)。loaded だけは
  // head に注入する Pagefind UI が遷移をまたいで生存するためモジュールスコープで保持する。
  let loaded = false;

  const getDialog = () =>
    document.querySelector<HTMLDialogElement>("[data-search-dialog]");
  const getMount = () => document.getElementById("pagefind-search");

  async function ensureLoaded() {
    const mount = getMount();
    if (loaded || !mount) return;
    loaded = true;
    const bundlePath = mount.dataset.bundlePath || "/pagefind/";
    // Pagefind UI はビルド成果物 (dist/pagefind/) にしか無く、window.PagefindUI を
    // 定義する自己実行スクリプト。静的 import() で読み込むと Vite の preload ラッパに
    // 包まれ、本番ビルドで `__VITE_PRELOAD__ is not defined` になり読み込みに失敗する。
    // そのため Vite の変換を受けない <script>/<link> 注入で読み込む。
    // スクリプト読込・CSS注入・UI生成のいずれが失敗しても loaded を戻し、再オープンで再試行する。
    try {
      await new Promise<void>((resolve, reject) => {
        const s = document.createElement("script");
        s.src = `${bundlePath}pagefind-ui.js`;
        s.onload = () => resolve();
        s.onerror = () =>
          reject(new Error("Pagefind UI の読み込みに失敗しました"));
        document.head.appendChild(s);
      });
      const css = document.createElement("link");
      css.rel = "stylesheet";
      css.href = `${bundlePath}pagefind-ui.css`;
      document.head.appendChild(css);
      // @ts-expect-error: グローバルに公開される PagefindUI
      new window.PagefindUI({
        element: "#pagefind-search",
        bundlePath,
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: "キーワードを入力",
          zero_results: "「[SEARCH_TERM]」に一致する結果はありません",
        },
      });
    } catch (e) {
      loaded = false; // 失敗時は再オープンで再試行できるようにする
      throw e;
    }
  }

  // 索引が無い/読み込み失敗時に mount へ案内を出す (静的文字列のみ)
  function showMessage(text: string) {
    const mount = getMount();
    if (mount) mount.innerHTML = `<p class="search-dialog__note">${text}</p>`;
  }

  async function openSearch() {
    const dialog = getDialog();
    if (!dialog) return;
    const closeBtn = dialog.querySelector<HTMLElement>("[data-search-close]");
    dialog.showModal();
    // dev には Pagefind 索引が無い。無言の故障に見えないよう明示する。
    if (import.meta.env.DEV) {
      showMessage(
        "検索はビルド版 (bun run build → preview) でのみ有効です。dev では索引がありません。",
      );
      closeBtn?.focus();
      return;
    }
    try {
      await ensureLoaded();
    } catch {
      showMessage("検索の読み込みに失敗しました。ページを再読み込みしてください。");
      closeBtn?.focus();
      return;
    }
    // Pagefind UI のマウント後に検索入力へフォーカス (無ければ閉じるボタン)
    requestAnimationFrame(() => {
      const input = dialog.querySelector<HTMLInputElement>("input[type='text']");
      (input ?? closeBtn)?.focus();
    });
  }

  // 開くボタン (ヘッダー) と、遷移ごとに差し替わる dialog 自身 (閉じる/背景クリック) を
  // 都度バインドし直す。dataset.bound で同一ノードへの二重登録を防ぐ。
  function bind() {
    document.querySelectorAll<HTMLElement>("[data-search-open]").forEach((el) => {
      if (el.dataset.bound) return;
      el.dataset.bound = "1";
      el.addEventListener("click", openSearch);
    });
    const dialog = getDialog();
    if (dialog && !dialog.dataset.bound) {
      dialog.dataset.bound = "1";
      dialog
        .querySelector("[data-search-close]")
        ?.addEventListener("click", () => dialog.close());
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
      });
    }
  }

  // Cmd/Ctrl+K で検索を開く (document レベルなので遷移をまたいで1度で足りる)
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      openSearch();
    }
  });

  bind();
  document.addEventListener("astro:after-swap", bind);
</script>
