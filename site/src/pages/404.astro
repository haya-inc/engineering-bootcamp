---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import { docHref } from "../lib/content.ts";
import { videosIndexHref } from "../lib/videos.ts";
import { SITE_NAME } from "../lib/site.ts";

// GitHub Pages は未知パスにこの 404.html を返す。主要な導線と検索案内を必ず出す。
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const links = [
  { href: `${base}/`, label: "ホーム", body: "研修の入り口へ", icon: "ph:house" },
  { href: videosIndexHref(), label: "動画一覧", body: "全24章を視聴する", icon: "ph:play-circle" },
  {
    href: docHref("textbook/00-introduction"),
    label: "テキスト資料",
    body: "書籍形式で読む",
    icon: "ph:book-open",
  },
  { href: docHref("glossary/intro"), label: "用語解説", body: "専門用語を調べる", icon: "ph:cards-three" },
];
---

<BaseLayout
  title="ページが見つかりません"
  description={`${SITE_NAME}内に該当するページが見つかりませんでした。ホーム・動画・テキスト・用語解説から続けられます。`}
  contained={false}
  robots="noindex, follow"
>
  <section class="notfound">
    <p class="kicker" lang="en">404</p>
    <h1>ページが見つかりません</h1>
    <p class="notfound__lead">
      お探しのページは移動したか、URL が変わった可能性があります。下のいずれかから続けてください。ヘッダーの「検索」（⌘K
      / Ctrl K）でも教材内を探せます。
    </p>
    <ul class="notfound__links" role="list">
      {
        links.map((l) => (
          <li>
            <a href={l.href}>
              <Icon name={l.icon} aria-hidden="true" />
              <strong>{l.label}</strong>
              <span>{l.body}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .notfound {
    max-width: 760px;
    margin-inline: auto;
    padding: clamp(48px, 10vw, 120px) clamp(16px, 5vw, 48px);
  }
  .notfound h1 {
    font-size: clamp(28px, 5vw, 48px);
    margin-block: 4px 0;
  }
  .notfound__lead {
    margin-block-start: 16px;
    max-width: 60ch;
    color: var(--muted);
    font-size: 1.05rem;
  }
  .notfound__links {
    list-style: none;
    padding: 0;
    margin-block-start: 32px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }
  .notfound__links a {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 12px;
    align-items: center;
    padding: 16px 18px;
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    transition:
      translate 0.18s,
      border-color 0.18s;
  }
  .notfound__links a:hover {
    translate: 0 -2px;
    border-color: var(--accent);
  }
  .notfound__links svg {
    grid-row: 1 / 3;
    font-size: 1.6rem;
    color: var(--accent-text);
  }
  .notfound__links strong {
    font-size: 1.02rem;
  }
  .notfound__links span {
    color: var(--muted);
    font-size: 0.85rem;
  }
</style>
