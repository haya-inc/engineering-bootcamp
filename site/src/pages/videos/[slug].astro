---
import { getEntry, render } from "astro:content";
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import VideoProgressScript from "../../components/VideoProgressScript.astro";
import {
  getVideos,
  videoHref,
  videosIndexHref,
  docHref,
  youtubeThumb,
  youtubeEmbed,
  playlistEmbed,
  youtubeIframeAllow,
  watchUrl,
  type VideoMeta,
} from "../../lib/videos.ts";
import { SITE_NAME, SITE_PUBLISHER, SITE_PUBLISHER_URL } from "../../lib/site.ts";

export async function getStaticPaths() {
  const videos = await getVideos();
  return videos.map((video, i) => ({
    params: { slug: video.slug },
    props: {
      video,
      prev: videos[i - 1],
      next: videos[i + 1],
    },
  }));
}

interface Props {
  video: VideoMeta;
  prev?: VideoMeta;
  next?: VideoMeta;
}

const { video, prev, next } = Astro.props;
const embed = video.youtubeId ? youtubeEmbed(video.youtubeId) : playlistEmbed();
const heading = `第${video.chapter}章 ${video.title}`;
const description = `第${video.chapter}章「${video.title}」の動画を視聴し、テキスト・用語解説・台本・課題へ進めます。`;

// JSON-LD: 動画を VideoObject として宣言し、ホーム → 動画一覧 → この動画 のパンくずを添える。
// (uploadDate は videos.json に持たないため省略。Google のリッチリザルト適格性は限定されるが、
//  マークアップとしては妥当で、検索エンジンに動画ページであることを正しく伝えられる。)
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const homeUrl = new URL(`${base}/`, Astro.site).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    name: heading,
    description,
    inLanguage: "ja",
    url: canonical,
    ...(video.youtubeId
      ? {
          embedUrl: youtubeEmbed(video.youtubeId),
          thumbnailUrl: youtubeThumb(video.youtubeId),
          contentUrl: watchUrl(video),
        }
      : {}),
    isPartOf: { "@type": "WebSite", name: SITE_NAME, url: homeUrl },
    publisher: { "@type": "Organization", name: SITE_PUBLISHER, url: SITE_PUBLISHER_URL },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: homeUrl },
      {
        "@type": "ListItem",
        position: 2,
        name: "動画一覧",
        item: new URL(videosIndexHref(), Astro.site).toString(),
      },
      { "@type": "ListItem", position: 3, name: heading, item: canonical },
    ],
  },
];

// 動画台本 (scripts コレクション) があればページ内に描画する。
const scriptEntry = await getEntry("scripts", video.scriptId);
const ScriptContent = scriptEntry ? (await render(scriptEntry)).Content : null;

// 台本はページ内 (.video-script) に常時表示するので、教材リンクには「動画台本」を置かない。
const resources = [
  { label: "テキスト資料", href: docHref(video.textbookId), external: false, icon: "ph:book-open" },
  { label: "用語解説", href: docHref(video.glossaryId), external: false, icon: "ph:cards-three" },
  { label: "課題", href: video.assignmentUrl, external: true, icon: "ph:pencil-simple-line" },
];
---

<BaseLayout
  title={heading}
  description={description}
  contained={false}
  ogType="article"
  structuredData={structuredData}
  preconnect={["https://i.ytimg.com"]}
>
  <article class="video-detail">
    <header class="video-detail__head">
      <p class="video-detail__eyebrow">{video.partLabel}・動画</p>
      {/* 一覧のカードタイトル (vid-title-N) から見出しへ morph させる。サムネ (vid-thumb-N)
          と連動し、クリックしたカードがそのまま再生面+見出しへ展開する。 */}
      <h1 transition:name={`vid-title-${video.chapter}`}>{heading}</h1>
    </header>

    <div class="video-detail__media">
      <div
        class="video-embed"
        data-video-card
        data-chapter={video.chapter}
        data-watched="false"
      >
        <button
          type="button"
          class="video-embed__facade"
          transition:name={`vid-thumb-${video.chapter}`}
          data-yt-facade
          data-embed={embed}
          data-title={heading}
          aria-label={`動画を再生: ${heading}`}
        >
          {
            video.youtubeId ? (
              <img
                class="video-embed__thumb"
                src={youtubeThumb(video.youtubeId)}
                alt=""
                width="480"
                height="360"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            ) : (
              <span class="video-embed__ph" aria-hidden="true">
                <span class="video-embed__ph-tag">再生リストで視聴</span>
              </span>
            )
          }
          <span class="video-embed__play" aria-hidden="true"></span>
        </button>
        <noscript>
          <div class="video-embed__frame">
            <iframe
              src={embed}
              title={heading}
              loading="lazy"
              allow={youtubeIframeAllow}
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        </noscript>
      </div>

      {
        !video.youtubeId && (
          <p class="video-note">
            この章の個別動画 URL は未確認のため、再生すると再生リスト全体を表示します。最新の対応は
            README のチャプター一覧で確認できます。
          </p>
        )
      }

      <div class="video-actions">
        <button
          type="button"
          class="watch-toggle watch-toggle--lg"
          data-watch-toggle
          data-chapter={video.chapter}
          aria-pressed="false"
        >
          <span class="watch-toggle__box" aria-hidden="true"></span>
          <span data-watch-label>視聴済みにする</span>
        </button>
        <a
          class="button button--secondary"
          href={watchUrl(video)}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube で開く（外部サイト・新しいタブで開く）"
        >
          <Icon name="ph:youtube-logo" aria-hidden="true" />
          YouTube で開く
        </a>
      </div>

      <section class="video-resources" aria-label="この章の教材">
        {
          resources.map((r) => (
            <a
              class="resource"
              href={r.href}
              {...(r.external
                ? {
                    target: "_blank",
                    rel: "noopener noreferrer",
                    "aria-label": `${r.label}（外部サイト・新しいタブで開く）`,
                  }
                : {})}
            >
              <Icon class="resource__icon" name={r.icon} aria-hidden="true" />
              <strong class="resource__label">{r.label}</strong>
              {/* 外部リンク (課題) は別タブで開く。ヘッダーと同じ矢印アイコンで一目で分かるようにする。 */}
              {r.external && (
                <Icon name="ph:arrow-up-right" class="resource__ext" aria-hidden="true" />
              )}
            </a>
          ))
        }
      </section>

      {/* 前後の動画ページャは課題ボタン (video-resources) と同じ左カラム内・その直下に
          置く。sticky なメディア列と一体でスクロールさせ、ナビゲーションが課題ボタンと
          重なったり台本の下に埋もれたりしないようにする。 */}
      <nav class="doc-pager" aria-label="前後の動画">
        {
          prev ? (
            <a class="doc-pager__link doc-pager__link--prev" href={videoHref(prev.slug)}>
              <span>
                <Icon name="ph:arrow-left" aria-hidden="true" />前の動画
              </span>
              <strong>
                第{prev.chapter}章 {prev.title}
              </strong>
            </a>
          ) : (
            <span />
          )
        }
        {
          next ? (
            <a class="doc-pager__link doc-pager__link--next" href={videoHref(next.slug)}>
              <span>
                次の動画<Icon name="ph:arrow-right" aria-hidden="true" />
              </span>
              <strong>
                第{next.chapter}章 {next.title}
              </strong>
            </a>
          ) : (
            <span />
          )
        }
      </nav>
    </div>

    {
      ScriptContent && (
        <details class="video-script" id="script" open>
          <summary class="video-script__summary">
            動画台本
            <span class="video-script__hint">ナレーション全文</span>
          </summary>
          <div class="prose video-script__body">
            <ScriptContent />
          </div>
          <p class="video-script__source">
            <a
              href={video.scriptUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub で台本を見る（外部サイト・新しいタブで開く）"
            >
              <Icon name="ph:github-logo" aria-hidden="true" />
              GitHub で台本を見る
            </a>
          </p>
        </details>
      )
    }
  </article>

  <VideoProgressScript />
</BaseLayout>
