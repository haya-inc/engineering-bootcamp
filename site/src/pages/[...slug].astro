---
import { getCollection, render } from "astro:content";
import DocsLayout from "../layouts/DocsLayout.astro";
import { sortDocs, docHref } from "../lib/content.ts";
import {
  SITE_DESCRIPTION,
  SITE_NAME,
  SITE_PUBLISHER,
  SITE_PUBLISHER_URL,
} from "../lib/site.ts";

export async function getStaticPaths() {
  const docs = sortDocs(await getCollection("docs"));
  return docs.map((entry, index) => {
    // テキスト資料と用語解説は別教材なので、ページャ (前へ/次へ) も
    // 同じ section 内で閉じる。境界 (隣が別 section) では出さない。
    // docs は section 順に並ぶので、隣接エントリの section を見れば足りる。
    const prevEntry = docs[index - 1];
    const nextEntry = docs[index + 1];
    const prev = prevEntry?.data.section === entry.data.section ? prevEntry : undefined;
    const next = nextEntry?.data.section === entry.data.section ? nextEntry : undefined;
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prev: prev ? { href: docHref(prev.id), title: prev.data.title } : undefined,
        next: next ? { href: docHref(next.id), title: next.data.title } : undefined,
      },
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content, headings } = await render(entry);

// 用語解説の用語ページ (凡例の intro を除く) は用語のカード表示を使う。
const isGlossaryTerms = entry.data.section === "glossary" && entry.id !== "glossary/intro";

// JSON-LD: 各章を Article として宣言し、ホーム → セクション → 章 のパンくずを添える。
// item は絶対 URL が必要なので Astro.site で解決する (BaseLayout の canonical と同じ作法)。
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const abs = (path: string) => new URL(path, Astro.site).toString();
const homeUrl = abs(`${base}/`);
const canonical = abs(Astro.url.pathname);
const description = entry.data.description ?? SITE_DESCRIPTION;
const sectionCrumb =
  entry.data.section === "glossary"
    ? { name: "用語解説", item: abs(docHref("glossary/intro")) }
    : { name: "テキスト資料", item: abs(docHref("textbook/00-introduction")) };

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: entry.data.title,
    description,
    inLanguage: "ja",
    url: canonical,
    isPartOf: { "@type": "WebSite", name: SITE_NAME, url: homeUrl },
    publisher: { "@type": "Organization", name: SITE_PUBLISHER, url: SITE_PUBLISHER_URL },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "ホーム", item: homeUrl },
      { "@type": "ListItem", position: 2, name: sectionCrumb.name, item: sectionCrumb.item },
      { "@type": "ListItem", position: 3, name: entry.data.title, item: canonical },
    ],
  },
];
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  currentId={entry.id}
  partLabel={entry.data.partLabel}
  headings={headings}
  prev={prev}
  next={next}
  glossary={isGlossaryTerms}
  structuredData={structuredData}
>
  <Content />
</DocsLayout>
