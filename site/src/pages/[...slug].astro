---
import { getCollection, render } from "astro:content";
import DocsLayout from "../layouts/DocsLayout.astro";
import { sortDocs, docHref } from "../lib/content.ts";

export async function getStaticPaths() {
  const docs = sortDocs(await getCollection("docs"));
  return docs.map((entry, index) => {
    // テキスト資料と用語解説は別教材なので、ページャ (前へ/次へ) も
    // 同じ section 内で閉じる。境界 (隣が別 section) では出さない。
    // docs は section 順に並ぶので、隣接エントリの section を見れば足りる。
    const prevEntry = docs[index - 1];
    const nextEntry = docs[index + 1];
    const prev = prevEntry?.data.section === entry.data.section ? prevEntry : undefined;
    const next = nextEntry?.data.section === entry.data.section ? nextEntry : undefined;
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prev: prev ? { href: docHref(prev.id), title: prev.data.title } : undefined,
        next: next ? { href: docHref(next.id), title: next.data.title } : undefined,
      },
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content, headings } = await render(entry);

// 用語解説の用語ページ (凡例の intro を除く) はカード表示+索引UIを使う。
const isGlossaryTerms = entry.data.section === "glossary" && entry.id !== "glossary/intro";
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  currentId={entry.id}
  partLabel={entry.data.partLabel}
  headings={headings}
  prev={prev}
  next={next}
  glossary={isGlossaryTerms}
>
  <Content />
</DocsLayout>
