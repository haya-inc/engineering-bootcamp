---
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SearchDialog from "../components/SearchDialog.astro";
import {
  SITE_ALTERNATE_NAME,
  SITE_DESCRIPTION,
  SITE_NAME,
  SITE_OG_IMAGE_ALT,
  SITE_PUBLISHER,
  SITE_PUBLISHER_URL,
} from "../lib/site.ts";
import "../styles/custom.css";

interface Props {
  title: string;
  description?: string;
  /** ドキュメントページなど、本文を中央寄せの prose 幅にしない場合は false */
  contained?: boolean;
  ogType?: "website" | "article";
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  /**
   * robots メタの内容。既定 (未指定) では meta robots を出力しない。
   * index/follow はクローラの既定動作で Google は明示しても無視するため、通常ページでは付けない。
   * 既定を変えたいページ (例: 404 の "noindex, follow") でのみ渡す。
   */
  robots?: string;
  /** 早めに TCP/TLS を張っておきたい外部オリジン (例: 動画ページの YouTube サムネ配信元)。 */
  preconnect?: string[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  contained = true,
  ogType = "website",
  structuredData = [],
  robots,
  preconnect = [],
} = Astro.props;

const siteName = SITE_NAME;
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = new URL(`${base}/`, Astro.site);
const ogImage = new URL(`${base}/og-image.jpg`, Astro.site);
const favicon = `${base}/favicon.svg`;
const faviconPng = `${base}/favicon-32x32.png`;
const faviconIco = `${base}/favicon.ico`;
const appleTouchIcon = `${base}/apple-touch-icon.png`;
const structuredDataItems = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    alternateName: SITE_ALTERNATE_NAME,
    url: siteUrl.toString(),
    inLanguage: "ja",
    description: SITE_DESCRIPTION,
    publisher: {
      "@type": "Organization",
      name: SITE_PUBLISHER,
      url: SITE_PUBLISHER_URL,
    },
  },
  ...(Array.isArray(structuredData) ? structuredData : [structuredData]),
];
// `<` だけ < へ退避すれば、JSON 文字列値に "</script>" 等が混じっても script 要素を
// 閉じられない (XSS 防止)。現状は静的データのみだが、将来 frontmatter 由来の値を入れても安全。
const jsonLd = JSON.stringify(structuredDataItems).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content={siteName} />
    <meta name="author" content={SITE_PUBLISHER} />
    {/* 通常ページは robots を出力しない (index,follow はクローラ既定で Google は無視する)。
        404 など既定を変えたいページだけ Props 経由で noindex 等を渡す。 */}
    {robots && <meta name="robots" content={robots} />}
    {/* モバイルのブラウザ UI 色を本文背景 (--bg) に合わせ、OS のライト/ダークへ追従させる。
        手動テーマトグルは OS 設定までは上書きしないが、OS 既定の利用者には地続きの見え方になる。 */}
    <meta name="theme-color" content="#f6f3ec" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#131210" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={favicon} type="image/svg+xml" sizes="any" />
    <link rel="icon" href={faviconPng} type="image/png" sizes="32x32" />
    <link rel="icon" href={faviconIco} sizes="32x32" />
    <link rel="apple-touch-icon" href={appleTouchIcon} />
    {/* ページが指定した外部オリジンへ事前接続 (動画ページの i.ytimg.com など)。サムネは別オリジン
        画像なので crossorigin は付けない (anonymous 画像取得の接続を再利用させる)。 */}
    {preconnect.map((origin) => (
      <link rel="preconnect" href={origin} />
    ))}
    {/* 欧文 Inter をセルフホスト。@font-face 生成 + above-the-fold 用に preload */}
    <Font cssVariable="--font-sans-web" preload />
    {/* ブランドワードマーク「エンジニア入門研修」専用書体 (9文字サブセット)。
        ヘッダーのブランド名とヒーロー見出しは above-the-fold なので preload する。 */}
    <Font cssVariable="--font-brand" preload />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href={new URL(`${base}/sitemap-index.xml`, Astro.site)} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE_OG_IMAGE_ALT} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={SITE_OG_IMAGE_ALT} />
    <script type="application/ld+json" is:inline set:html={jsonLd} />
    {/* テーマ初期化: 描画前に data-theme を確定させ、ちらつきを防ぐ */}
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const saved = localStorage.getItem("theme");
        const theme =
          saved ??
          (matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        root.dataset.theme = theme;
        // 検索ショートカットの表記を OS に合わせる (Mac=⌘K / その他=Ctrl K)。
        // 描画前に html[data-os] を確定させ、表記のちらつきを防ぐ。
        const detectOS = () => {
          const ua =
            navigator.userAgentData?.platform ||
            navigator.platform ||
            navigator.userAgent ||
            "";
          root.dataset.os = /mac|iphone|ipad|ipod/i.test(ua) ? "mac" : "other";
        };
        detectOS();
        // View Transitions のページ遷移後も テーマ / OS 表記を維持する
        document.addEventListener("astro:after-swap", () => {
          const t = localStorage.getItem("theme");
          if (t) root.dataset.theme = t;
          detectOS();
        });
      })();
    </script>
    <ClientRouter />
  </head>
  <body data-contained={contained ? "" : undefined}>
    <a class="skip-link" href="#main">本文へスキップ</a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <SearchDialog />
  </body>
</html>
